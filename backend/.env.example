PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/onshore_reputation
MONGODB_DB=onshore_reputation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# CORS — comma-separated for multiple origins
# Development: http://localhost:5173
# Production: https://onshore-labs.vercel.app
CORS_ORIGIN=http://localhost:5173,https://onshore-labs.vercel.app
# Production example: CORS_ORIGIN=http://localhost:5173,https://onshore-labs.vercel.app

# ── Review connectors — FREE, no credit card required ─────────────────────────
#
# Reddit runs automatically with NO key at all.
#
# SerpAPI  (Google Maps reviews + Yelp reviews)
#   → Sign up FREE at https://serpapi.com  (100 searches/month, no card)
#   → Dashboard → Your Account → API Key
SERPAPI_KEY=
#
# Apify  (Google Maps reviews + TripAdvisor reviews)
#   → Sign up FREE at https://apify.com  ($5/month platform credits, no card)
#   → Settings → Integrations → Personal API Tokens → Create
APIFY_TOKEN=
#
# NOTE: Google Places API was excluded — it requires a billing account
#       with a credit card, even for the free tier.


